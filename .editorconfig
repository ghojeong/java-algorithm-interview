root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{java,kt,kts}]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{kt,kts}]
# 이 프로젝트의 문제 파일 네이밍 패턴(P96_2, P97_5 등)은 의도적이므로 비활성화
ktlint_standard_class-naming = disabled

[*.xml]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Checkstyle 설정 — 포맷 규칙은 제외 (Spotless/google-java-format이 담당)
  여기서는 네이밍 컨벤션, import 정리, 코드 품질만 검사합니다.

  검사 항목 요약:
    • Imports  : 미사용·중복·불필요한 import
    • Naming   : 패키지·클래스·메서드 이름 규칙 (알고리즘 특성상 관대하게 설정)
    • Quality  : equals/hashCode 짝 누락, switch fall-through, 문자열 == 비교 등
    • Modifiers: 접근 제어자 순서 및 중복 선언
    • Override : @Override 누락

  억제(suppress) 방법:
    코드에 @SuppressWarnings("checkstyle:<RuleName>") 추가
-->

<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- @SuppressWarnings 어노테이션 지원 -->
    <module name="SuppressWarningsFilter"/>

    <!-- module-info.java 제외 -->
    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern" value="module-info\.java$"/>
    </module>

    <module name="TreeWalker">
        <module name="SuppressWarningsHolder"/>

        <!-- ── Imports ─────────────────────────────────────────────────── -->
        <!-- 미사용 import (google-java-format의 removeUnusedImports와 이중 방어) -->
        <module name="UnusedImports"/>
        <!-- 같은 클래스를 두 번 import -->
        <module name="RedundantImport"/>
        <!-- java.* / sun.* 등 내부 API 직접 사용 금지 -->
        <module name="IllegalImport"/>

        <!-- ── Naming Conventions ──────────────────────────────────────── -->
        <!-- 패키지명: 소문자만 -->
        <module name="PackageName">
            <property name="format" value="^[a-z][a-z0-9]*(\.[a-z][a-z0-9]*)*$"/>
        </module>
        <!--
          클래스/인터페이스명: 대문자로 시작
          이 프로젝트의 문제 파일 네이밍 패턴(P64_1, P87_2 등) 허용을 위해
          언더스코어와 숫자를 포함한 포맷 사용
        -->
        <module name="TypeName">
            <property name="format" value="^[A-Z][a-zA-Z0-9_]*$"/>
        </module>
        <!--
          메서드명: 소문자로 시작 또는 알고리즘 문제 번호 형식 허용
          예) isPalindrome, twoSum, P1_1 (문제 번호 테스트 메서드)
        -->
        <module name="MethodName">
            <property name="format" value="^[a-zA-Z][a-zA-Z0-9_]*$"/>
        </module>
        <!--
          멤버/파라미터/지역 변수: 알고리즘 특성상 s_filtered, dp, l, r 등 허용
        -->
        <module name="MemberName">
            <property name="format" value="^[a-zA-Z][a-zA-Z0-9_]*$"/>
        </module>
        <module name="ParameterName">
            <property name="format" value="^[a-zA-Z][a-zA-Z0-9_]*$"/>
        </module>
        <module name="LocalVariableName">
            <property name="format" value="^[a-zA-Z][a-zA-Z0-9_]*$"/>
        </module>
        <!-- 상수: 대문자 + 언더스코어 -->
        <module name="ConstantName"/>
        <!-- 제네릭 타입 파라미터: 단일 대문자 (T, E, K, V, R 등) -->
        <module name="ClassTypeParameterName">
            <property name="format" value="^[A-Z][0-9]?$"/>
        </module>
        <module name="MethodTypeParameterName">
            <property name="format" value="^[A-Z][0-9]?$"/>
        </module>
        <module name="InterfaceTypeParameterName">
            <property name="format" value="^[A-Z][0-9]?$"/>
        </module>

        <!-- ── Code Quality ────────────────────────────────────────────── -->
        <!-- equals() 오버라이드 시 hashCode()도 반드시 오버라이드 -->
        <module name="EqualsHashCode"/>
        <!-- switch fall-through (의도적이면 // falls through 주석 추가) -->
        <module name="FallThrough"/>
        <!-- 문자열 == 비교 금지 (equals 사용) -->
        <module name="StringLiteralEquality"/>
        <!-- true == expr 형식의 불필요한 비교 -->
        <module name="SimplifyBooleanExpression"/>
        <!-- if (cond) return true; else return false; 형식 금지 -->
        <module name="SimplifyBooleanReturn"/>
        <!-- 빈 구문 방지: for (;;); -->
        <module name="EmptyStatement"/>

        <!-- ── Modifiers ───────────────────────────────────────────────── -->
        <!-- Java 권장 순서: public protected private abstract static ... -->
        <module name="ModifierOrder"/>
        <!-- 인터페이스 메서드의 public abstract 등 중복 선언 금지 -->
        <module name="RedundantModifier"/>

        <!-- ── Annotations ─────────────────────────────────────────────── -->
        <!-- 오버라이드 메서드에 @Override 필수 -->
        <module name="MissingOverride"/>
    </module>
</module>
